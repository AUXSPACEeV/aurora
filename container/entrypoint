set -e

################################################################################
# Functions                                                                    #
################################################################################

function first_boot_actions() {
  local tmp_dir=$(dirname -- "$FIRST_BOOT_TMP_FLAG")

  if [ "${ZEPHYR_WORKSPACE}" != $(dirname "$AURORA_APPLICATION_DIR") ]; then
    echo "WARNING: ${ZEPHYR_WORKSPACE} != $(dirname $AURORA_APPLICATION_DIR)"
  fi

  cd "${ZEPHYR_WORKSPACE}"
  if [ ! -d "./modules" ]; then
    west init --local "${AURORA_APPLICATION_DIR}" --mf west.yml
  fi
  west update
  west zephyr-export
  pip install -r ./zephyr/scripts/requirements.txt
  source ./zephyr/zephyr-env.sh
  west packages pip --install

  # Setup tmp_dir if not already done
  sudo mkdir -p "$tmp_dir"
  sudo chown -R builder:builder "$tmp_dir"

  # Signalize our success
  touch "${FIRST_BOOT_TMP_FLAG}"
}

# TODO: Build functions

function build_app() {
  echo "INFO: Building \"${ZEPHYR_APPLICATION}\" for ${ZEPHYR_BOARD} ..."

  cd "${AURORA_APPLICATION_DIR}"
  west build -b "${ZEPHYR_BOARD}" "${ZEPHYR_APPLICATION}"
}

function clean_app() {
  echo "INFO: Cleaning ${AURORA_APPLICATION_DIR} ..."

  cd "${AURORA_APPLICATION_DIR}"
  rm -rf ./build ./.cache ./twister-out*
}

function do_menuconfig() {
  echo "INFO: Building menuconfig for ${ZEPHYR_BOARD} ..."

  cd "${AURORA_APPLICATION_DIR}"
  west build -b ${ZEPHYR_BOARD} ${ZEPHYR_APPLICATION} -t menuconfig
}

################################################################################
# Variables                                                                    #
################################################################################

COMMAND="/bin/bash"
declare -a ARGS=()

# Flag that shows if everything has already been initialized.
FIRST_BOOT_TMP_FLAG="/var/auxspace/first_boot"

# Detect if we need to drop privileges (Podman runs as root)
USE_GOSU=0
if [ "$(id -u)" = "0" ] && [ -n "${BUILDER_HOME}" ]; then
  USE_GOSU=1
fi

################################################################################
# Run first boot code to setup the environment correctly                       #
################################################################################

if [ ! -f "$FIRST_BOOT_TMP_FLAG" ]; then
  first_boot_actions

  # Fix ownership when running as root (Podman)
  if [ "$USE_GOSU" = "1" ]; then
    chown -R builder:builder "${BUILDER_HOME}"
  fi
fi

################################################################################
# Commandline arg parser                                                       #
################################################################################

while [ $# -gt 0 ]; do
  case $1 in
    -b|--board)
      declare -x BOARD="$2"
      shift 2
      ;;
    build)
      COMMAND=build_app
      shift
      ;;
    clean)
      COMMAND=clean_app
      shift
      ;;
    menuconfig)
      COMMAND="do_menuconfig"
      shift
      ;;
    shell)
      COMMAND="/bin/bash"
      shift
      ;;
    --*)
      echo "ERROR: No such option: $1"
      exit 1
      ;;
    *)
      echo "ERROR: No such command: ${1}"
      exit 1
      ;;
  esac
done

################################################################################
# Run command                                                                  #
################################################################################

if [ "$USE_GOSU" = "1" ]; then
  exec gosu builder $COMMAND ${ARGS[@]}
fi

$COMMAND ${ARGS[@]}
