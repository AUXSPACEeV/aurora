module = AURORA_SENSORS
module-str = AURORA_SENSORS
source "subsys/logging/Kconfig.template.log_config"

config AURORA_SENSORS
	bool "Support for sensor HAL"
	default y if SENSOR
	help
		This option enables functionality for the aurora sensor HAL.

menu "Inertial Measurement Unit (IMU)"

config IMU
	bool "Support for IMU"
	depends on AURORA_SENSORS
	default y if LSM6DSO
	help
		This option enables functionality for the Inertial Measurement
		Unit (IMU).

config IMU_TRIGGER
	bool "Support for IMU Trigger"
	depends on IMU
	default y if LSM6DSO_TRIGGER
	help
		This option enables functionality for the IMU
		to run triggers in an interrupt context.

config IMU_WATCHDOG
	bool "IMU stall watchdog (trigger mode)"
	depends on IMU && IMU_TRIGGER
	default y
	help
	  Periodically check that the IMU is still publishing samples on the
	  zbus channel. If no sample arrives within IMU_WATCHDOG_TIMEOUT_MS,
	  re-apply the configured ODR and re-arm the data-ready trigger. Acts
	  as a safety net against IMU soft-resets caused by power-rail
	  transients (e.g. cap-pyro arming inrush).

config IMU_WATCHDOG_TIMEOUT_MS
	int "IMU stall watchdog timeout (ms)"
	depends on IMU_WATCHDOG
	default 200
	range 50 10000
	help
	  Maximum allowed time between two consecutive IMU samples before the
	  watchdog declares the IMU stalled and triggers recovery.

config IMU_WATCHDOG_PERIOD_MS
	int "IMU stall watchdog check period (ms)"
	depends on IMU_WATCHDOG
	default 100
	range 10 1000
	help
	  How often the watchdog thread wakes up to check the publish age.

config IMU_WATCHDOG_RECOVERY_HZ
	int "IMU sampling frequency (Hz) re-applied during watchdog recovery"
	depends on IMU_WATCHDOG
	default 104
	range 1 1000
	help
	  ODR re-applied to the accelerometer and gyroscope when the watchdog
	  attempts recovery. Must match the IMU's intended operating ODR
	  (which is normally set by the device tree). Defaults to 104 Hz.

# Only show frequency options when IMU is enabled
choice IMU_FREQUENCY
	prompt "IMU update frequency (Hz)"
	depends on IMU
	default IMU_FREQ_10HZ

config IMU_FREQ_10HZ
	bool "10 Hz"

config IMU_FREQ_50HZ
	bool "50 Hz"

config IMU_FREQ_100HZ
	bool "100 Hz"

config IMU_FREQ_200HZ
	bool "200 Hz"

config IMU_FREQ_400HZ
	bool "400 Hz"

endchoice

config IMU_FREQUENCY_VALUE
	int
	depends on IMU
	default 10  if IMU_FREQ_10HZ
	default 50  if IMU_FREQ_50HZ
	default 100 if IMU_FREQ_100HZ
	default 200 if IMU_FREQ_200HZ
	default 400 if IMU_FREQ_400HZ

choice IMU_UP_AXIS
	prompt "IMU body axis pointing up the rocket's long axis"
	depends on IMU || ATTITUDE
	default IMU_UP_AXIS_POS_Z
	help
	  Selects which IMU body-frame axis points toward the rocket's nose
	  when the rocket is vertical on the launch pad. Used to seed the
	  gravity vector for body-to-world projection of accelerometer data.

config IMU_UP_AXIS_POS_X
	bool "+X"
config IMU_UP_AXIS_NEG_X
	bool "-X"
config IMU_UP_AXIS_POS_Y
	bool "+Y"
config IMU_UP_AXIS_NEG_Y
	bool "-Y"
config IMU_UP_AXIS_POS_Z
	bool "+Z"
config IMU_UP_AXIS_NEG_Z
	bool "-Z"

endchoice

config IMU_UP_AXIS_INDEX
	int
	depends on IMU || ATTITUDE
	default 0 if IMU_UP_AXIS_POS_X || IMU_UP_AXIS_NEG_X
	default 1 if IMU_UP_AXIS_POS_Y || IMU_UP_AXIS_NEG_Y
	default 2 if IMU_UP_AXIS_POS_Z || IMU_UP_AXIS_NEG_Z

config IMU_UP_AXIS_SIGN
	int
	depends on IMU || ATTITUDE
	default 1  if IMU_UP_AXIS_POS_X || IMU_UP_AXIS_POS_Y || IMU_UP_AXIS_POS_Z
	default -1 if IMU_UP_AXIS_NEG_X || IMU_UP_AXIS_NEG_Y || IMU_UP_AXIS_NEG_Z

config IMU_CALIBRATION_SAMPLES
	int "IMU calibration samples"
	depends on IMU
	default 200
	range 10 10000
	help
	  Number of IMU samples to average while the rocket is stationary in
	  ARMED for accelerometer/gyroscope bias estimation and gravity
	  magnitude measurement. At IMU_FREQUENCY_VALUE Hz, the calibration
	  window is roughly IMU_CALIBRATION_SAMPLES / IMU_FREQUENCY_VALUE
	  seconds.

config ATTITUDE
	bool "Attitude tracker (body-frame gravity vector)"
	default y if IMU
	help
	  Builds the gyro-integrated body-frame gravity tracker used to
	  project accelerometer readings onto world vertical.  Requires
	  CONFIG_IMU_UP_AXIS_* to be set.

endmenu

menu "Barometric Pressure Sensor (BARO)"

config BARO
	bool "Support for Baro"
	depends on AURORA_SENSORS
	default y if MS5607 || LPS22HH
	help
		This option enables functionality for barometric pressure
		sensors.

config BARO_TRIGGER
	bool "Support for Baro Trigger"
	depends on BARO
	default y if LPS22HH_TRIGGER
	help
		This option enables functionality for barometric pressure
		sensors to run triggers in an interrupt context.

config BARO_WATCHDOG
	bool "Baro stall watchdog (trigger mode)"
	depends on BARO && BARO_TRIGGER
	default y
	help
	  Periodically check that the barometer is still publishing samples on
	  the zbus channel. If no sample arrives within BARO_WATCHDOG_TIMEOUT_MS,
	  re-apply the configured ODR and re-arm the data-ready trigger. Acts as
	  a safety net against baro soft-resets caused by power-rail transients
	  (e.g. cap-pyro arming inrush).

config BARO_WATCHDOG_TIMEOUT_MS
	int "Baro stall watchdog timeout (ms)"
	depends on BARO_WATCHDOG
	default 200
	range 50 10000
	help
	  Maximum allowed time between two consecutive baro samples before the
	  watchdog declares the baro stalled and triggers recovery.

config BARO_WATCHDOG_PERIOD_MS
	int "Baro stall watchdog check period (ms)"
	depends on BARO_WATCHDOG
	default 100
	range 10 1000
	help
	  How often the watchdog thread wakes up to check the publish age.

config BARO_WATCHDOG_RECOVERY_HZ
	int "Baro sampling frequency (Hz) re-applied during watchdog recovery"
	depends on BARO_WATCHDOG
	default 100
	range 1 1000
	help
	  ODR re-applied to the barometer when the watchdog attempts recovery.
	  Must match the baro's intended operating ODR (which is normally set
	  by the device tree). Defaults to 100 Hz (LPS22HH).

# Only show frequency options when BARO is enabled
choice BARO_FREQUENCY
	prompt "BARO update frequency (Hz)"
	depends on BARO
	default BARO_FREQ_10HZ

config BARO_FREQ_10HZ
	bool "10 Hz"

config BARO_FREQ_50HZ
	bool "50 Hz"

config BARO_FREQ_100HZ
	bool "100 Hz"

config BARO_FREQ_200HZ
	bool "200 Hz"

config BARO_FREQ_400HZ
	bool "400 Hz"

endchoice

config BARO_FREQUENCY_VALUE
	int
	depends on BARO
	default 10  if BARO_FREQ_10HZ
	default 50  if BARO_FREQ_50HZ
	default 100 if BARO_FREQ_100HZ
	default 200 if BARO_FREQ_200HZ
	default 400 if BARO_FREQ_400HZ

endmenu
