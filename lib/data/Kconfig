config DATA_LOGGER
	bool "Generic telemetry data logger"
	depends on FILE_SYSTEM
	help
	  Enable the format-agnostic data logger for flight telemetry.
	  Sensor readings are captured as datapoints and serialised through
	  a pluggable formatter backend (CSV, InfluxDB line protocol, ...).

if DATA_LOGGER

module = DATA_LOGGER
module-str = data_logger
source "subsys/logging/Kconfig.template.log_config"

choice DATA_LOGGER_TYPE
	bool "Type of the data logger"
	default DATA_LOGGER_CSV

config DATA_LOGGER_CSV
	bool "CSV formatter"
	help
	  Include the CSV formatter backend.  Produces a UTF-8 file with one
	  header row followed by one row per datapoint.

config DATA_LOGGER_INFLUX
	bool "InfluxDB Line Protocol formatter"
	help
	  Include the InfluxDB Line Protocol formatter backend.  Produces one
	  line per datapoint; no header row.

config DATA_LOGGER_MOCK
	bool "Mock formatter (test only)"
	help
	  Select an externally provided mock formatter for unit testing the
	  core dispatch layer.  The symbol data_logger_mock_formatter must be
	  defined by the test application.

endchoice

config DATA_LOGGER_BASE_PATH
	string "Output directory for data logger files"
	default "/data"
	help
	  Directory where the data logger writes output files.  The final
	  path is <base_path>/<filename>.<file_ext>, where filename is
	  passed to data_logger_init() and file_ext comes from the active
	  formatter backend.

config DATA_LOGGER_MAX_FILES
	int "Maximum number of log files in DATA_LOGGER_BASE_PATH"
	default 200
	help
	  Maximum number of files in the directory where the data logger writes
	  output files.
	  If the maximum is reached, old files are overwritten.

if DATA_LOGGER_INFLUX

config DATA_LOGGER_INFLUX_MEASUREMENT
	string "InfluxDB measurement name"
	default "telemetry"
	help
	  The measurement name embedded in every InfluxDB line protocol record.

endif # DATA_LOGGER_INFLUX

config DATA_LOGGER_MAX_LOGGERS
	int "Maximum number of data logger instances"
	default 4
	help
	  Upper bound on the number of data loggers that can be registered
	  simultaneously.  Each slot costs one pointer in a static array.

config DATA_LOGGER_SHELL
	bool "Data logger shell commands"
	depends on SHELL
	help
	  Enable shell commands for listing, starting, stopping, flushing,
	  and querying the status of registered data loggers.

endif # DATA_LOGGER
