config DATA_LOGGER
	bool "Generic telemetry data logger"
	help
	  Enable the format-agnostic data logger for flight telemetry.
	  During flight (ARMED→LANDED), datapoints are appended to a
	  raw flash partition (see DATA_LOGGER_BIN).  On transition to
	  IDLE, LANDED or ERROR the binary log is streamed through one
	  or more conversion targets (CSV, InfluxDB line protocol)
	  written to the filesystem.

if DATA_LOGGER

module = DATA_LOGGER
module-str = data_logger
source "subsys/logging/Kconfig.template.log_config"

config DATA_LOGGER_BIN
	bool "Build the binary formatter (flight-time)"
	default y
	help
	  Build the live flight-time binary log writer and the post-flight
	  converter.  The on-storage layout is the same regardless of
	  backend: a sequence of fixed-size frames, each containing a
	  32-byte header and densely packed 32-byte records that preserve
	  the sensor_value channels losslessly.  Pick the backend below.

if DATA_LOGGER_BIN

choice DATA_LOGGER_BIN_BACKEND
	prompt "Binary log backend"
	default DATA_LOGGER_BIN_BACKEND_FLASH
	help
	  Select where the live binary log is written.  FLASH targets a
	  fixed flash partition (DT chosen 'auxspace,flight-log') and
	  treats the partition as a circular ring with boost-freeze
	  semantics.  DISK writes raw sectors of a Zephyr disk-access
	  block device (DT chosen 'auxspace,flight-log-disk') linearly
	  from the configured offset; sized for many minutes of flight on
	  an SD card without circular tricks.

config DATA_LOGGER_BIN_BACKEND_FLASH
	bool "Internal flash partition (circular)"
	select FLASH
	select FLASH_MAP
	help
	  Live log lives on a fixed-partition node selected via DT chosen
	  'auxspace,flight-log'.  Recommended for boards with limited
	  flash where the partition holds well under one flight worth of
	  data — circular pre-boost capture trades old data for new while
	  preserving the BOOST→LANDED window once the BOOST event fires.

config DATA_LOGGER_BIN_BACKEND_DISK
	bool "Disk-access block device (linear)"
	select DISK_ACCESS
	help
	  Live log lives on a sector range of a Zephyr disk-access device
	  (typically an SD card via zephyr,sdmmc-disk).  The region is
	  described by the DT chosen 'auxspace,flight-log-disk' node, an
	  'auxspaceev,flight-log-disk' compatible providing disk-name,
	  offset-sectors and size-sectors.  Capacity is large enough that
	  the writer is purely linear from the offset; circular wrap is
	  not used and BOOST events are recorded but do not freeze the
	  ring.

endchoice

config DATA_LOGGER_BIN_FRAME_SIZE
	int "Binary log frame size (bytes)"
	default 4096
	help
	  Size of one on-flash frame.  Each frame begins with a 32-byte
	  header followed by densely packed 32-byte records; the writer
	  thread issues one flash_area_erase() + flash_area_write() per
	  frame.  Set this to the flash erase block size of the underlying
	  partition (typically 4096 for QSPI NOR).  Must be a multiple of
	  32 bytes and the flight_log partition size must be a multiple of
	  it.

config DATA_LOGGER_BIN_BUF_COUNT
	int "Number of binary log staging buffers (FLASH backend)"
	depends on DATA_LOGGER_BIN_BACKEND_FLASH
	default 3
	range 2 8
	help
	  Only used by the FLASH backend.  2 (double-buffer) is the minimum:
	  the producer fills one while the writer commits the other.  3
	  (triple-buffer) is enough to absorb the per-sector erase latency
	  (~25 ms on QSPI NOR).  More buffers cost more RAM with diminishing
	  returns.

config DATA_LOGGER_BIN_RING_FRAMES
	int "Frame slots in the binary log ring (DISK backend)"
	depends on DATA_LOGGER_BIN_BACKEND_DISK
	default 16
	help
	  Number of BIN_FRAME_SIZE slots in the contiguous ring buffer that
	  feeds the disk writer thread.  Must be a power of two.  Effective
	  capacity is RING_FRAMES - 1 committed frames (one slot is always
	  reserved for the producer).  SD cards stall for 100+ ms during
	  internal garbage collection; ring depth times frame size sets how
	  much telemetry can be buffered through such a stall before the
	  producer back-pressures.  At a 4 KiB frame size, 16 slots = 64 KiB
	  RAM and absorbs ~5 s of telemetry at the nominal record rate.

config DATA_LOGGER_BIN_MAX_BATCH_FRAMES
	int "Max frames coalesced into one disk_access_write (DISK backend)"
	depends on DATA_LOGGER_BIN_BACKEND_DISK
	default 8
	help
	  Cap on how many contiguous committed frames the writer thread
	  hands to disk_access_write() in a single call.  Larger batches
	  amortise the per-call overhead of the SD stack and the FTL prefers
	  multi-block transfers, but increase the size of any single bounce
	  buffer the lower layer might allocate.  The effective batch is
	  also bounded by the number of committed frames and the distance
	  to the physical ring wrap.

config DATA_LOGGER_BIN_BUF_ALIGN
	int "Alignment of binary log staging buffers (bytes)"
	default 32
	help
	  Staging buffers are aligned to this many bytes so the underlying
	  flash driver can DMA out of them without bounce-buffering.  32
	  covers the cache-line size of every supported MCU.

config DATA_LOGGER_BIN_WRITER_STACK_SIZE
	int "Binary log writer thread stack size (bytes)"
	default 1024

config DATA_LOGGER_BIN_WRITER_PRIO
	int "Binary log writer thread priority"
	default 10
	help
	  Should be a lower priority (higher number) than the upstream
	  logger thread that produces records, but high enough that the
	  flash partition is serviced promptly.

config DATA_LOGGER_BIN_PRODUCER_TIMEOUT_MS
	int "Max time the producer waits for a free staging buffer (ms)"
	default 50
	help
	  If every staging buffer is queued for the writer when a new
	  record arrives, the producer waits up to this many ms for the
	  writer to free one.  On timeout the rotation fails and upstream
	  records are dropped until the writer catches up.

config DATA_LOGGER_BIN_FLUSH_TIMEOUT_MS
	int "Max time bin_flush() waits for the writer to drain (ms)"
	default 2000

config DATA_LOGGER_BIN_POST_LANDED_PAD_MS
	int "Milliseconds of telemetry to capture after LANDED"
	default 5000
	help
	  After the state machine enters LANDED, the upstream caller keeps
	  the data logger open for this many ms before closing it.  Records
	  arriving during this window are normal post-landed telemetry;
	  combined with the pre-boost data already captured by the circular
	  ring, the converted log spans roughly
	  [BOOST minus whatever pre-boost padding fits in the ring,
	   LANDED + this value].

endif # DATA_LOGGER_BIN

config DATA_LOGGER_MOCK
	bool "Build mock formatter (test only)"
	help
	  Build against an externally provided mock formatter for unit
	  testing the core dispatch layer.  The symbol
	  data_logger_mock_formatter must be defined by the test
	  application.

config DATA_LOGGER_CONVERT_CSV
	bool "Enable CSV conversion target"
	default y
	depends on FILE_SYSTEM
	help
	  Build the CSV formatter so data_logger_convert() can emit a
	  header-prefixed UTF-8 CSV file from the binary log.

config DATA_LOGGER_CONVERT_INFLUX
	bool "Enable InfluxDB Line Protocol conversion target"
	depends on FILE_SYSTEM
	help
	  Build the InfluxDB line-protocol formatter so data_logger_convert()
	  can emit one InfluxDB line per datapoint from the binary log.

config DATA_LOGGER_BASE_PATH
	string "Output directory for data logger files"
	default "/data"
	help
	  Directory where the data logger writes output files.  The final
	  path is <base_path>/<filename>.<file_ext>, where filename is
	  passed to data_logger_init() and file_ext comes from the active
	  formatter backend.

config DATA_LOGGER_MAX_FILES
	int "Maximum number of log files in DATA_LOGGER_BASE_PATH"
	default 200
	help
	  Maximum number of files in the directory where the data logger writes
	  output files.
	  If the maximum is reached, old files are overwritten.

if DATA_LOGGER_CONVERT_INFLUX

config DATA_LOGGER_INFLUX_MEASUREMENT
	string "InfluxDB measurement name"
	default "telemetry"
	help
	  The measurement name embedded in every InfluxDB line protocol record.

config DATA_LOGGER_INFLUX_BUF_SIZE
	int "RAM write buffer size in bytes"
	default 4096
	help
	  Datapoints are accumulated in this RAM buffer and only written to
	  the filesystem on flush.  A larger buffer reduces the number of
	  fs_write/fs_sync calls (better for SD card longevity and power-fail
	  safety) but uses more RAM.  Data that has not been flushed is lost
	  on power failure.

endif # DATA_LOGGER_CONVERT_INFLUX

config DATA_LOGGER_MAX_LOGGERS
	int "Maximum number of data logger instances"
	default 4
	help
	  Upper bound on the number of data loggers that can be registered
	  simultaneously.  Each slot costs one pointer in a static array.

config DATA_LOGGER_SHELL
	bool "Data logger shell commands"
	depends on SHELL
	help
	  Enable shell commands for listing, starting, stopping, flushing,
	  and querying the status of registered data loggers.

endif # DATA_LOGGER
