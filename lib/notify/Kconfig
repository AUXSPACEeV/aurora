config AURORA_NOTIFY
	bool "Notification subsystem"
	help
	  Enable the notification subsystem.  When enabled, registered
	  backends (buzzer, RGB LED, ...) are called on boot, state-machine
	  transitions, and error conditions.

if AURORA_NOTIFY

module = AURORA_NOTIFY
module-str = AURORA_NOTIFY
source "subsys/logging/Kconfig.template.log_config"

config AURORA_NOTIFY_BUZZER
	bool "PWM buzzer notifications"
	depends on PWM
	depends on DT_HAS_AUXSPACEEV_PWM_BUZZER_ENABLED
	select AURORA_PWM_MELODY
	help
	  Drive a passive buzzer via PWM to signal boot, state changes,
	  and errors. Plays a melody when landed.

if AURORA_NOTIFY_BUZZER

config AURORA_NOTIFY_BUZZER_QUEUE_SIZE
	int "Buzzer event queue depth"
	default 16
	range 1 128
	help
	  Maximum number of buzzer notification events that may be
	  queued before new events are dropped with a warning. Events
	  are played in FIFO order by a dedicated worker thread, so
	  ordering of sequences such as stop-melody-then-play-tone is
	  preserved.

config AURORA_NOTIFY_BUZZER_STACK_SIZE
	int "Buzzer worker thread stack size"
	default 1024
	help
	  Stack size (bytes) of the dedicated thread that plays queued
	  buzzer events.

config AURORA_NOTIFY_BUZZER_THREAD_PRIORITY
	int "Buzzer worker thread priority"
	default 10
	help
	  Zephyr priority of the buzzer worker thread. Lower numerical
	  values are higher priority; keep this numerically above
	  flight-critical threads (sensors, state machine — priority 5)
	  so notifications never preempt them.

endif # AURORA_NOTIFY_BUZZER

config AURORA_NOTIFY_LED
	bool "PWM LED notifications"
	depends on PWM
	depends on DT_HAS_PWM_LEDS_ENABLED
	help
	  Drive an LED via PWM to signal boot, state changes, and errors.

config AURORA_NOTIFY_DISK_LED
	bool "SD-card activity LED"
	depends on GPIO
	help
	  Drive the GPIO LED referenced by the "auxspace,disk-led" chosen
	  node as an SD-card activity indicator. Independent of the PWM
	  state-machine LED: it lights on disk writes and turns itself off
	  after a short idle window.

if AURORA_NOTIFY_DISK_LED

config AURORA_NOTIFY_DISK_LED_HOLD_MS
	int "SD activity LED hold time (ms)"
	default 40
	range 1 1000
	help
	  How long the SD activity LED stays lit after the most recent disk
	  access. Continuous writes keep it on; a pause longer than this
	  turns it off.

endif # AURORA_NOTIFY_DISK_LED

endif # AURORA_NOTIFY
