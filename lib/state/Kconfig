config AURORA_STATE_MACHINE
	bool "Support for state machine"
	help
		This option enables functionality for the aurora state machine
		lib.

if AURORA_STATE_MACHINE

module = STATE_MACHINE
module-str = STATE_MACHINE
source "subsys/logging/Kconfig.template.log_config"

choice AURORA_STATE_MACHINE_TYPE
	bool "State Machine Type"
	depends on AURORA_STATE_MACHINE
	default SIMPLE_STATE

config SIMPLE_STATE
	bool "Simple State machine"
	help
		Simple State machine with apogee detection, single pyro ignition
		and basic safety features.
		Ideal for small form factor boards and rockets.

endchoice

config AURORA_STATE_MACHINE_AUDIT
	bool "State machine audit log"
	default y
	help
	  Enable a ring-buffer audit log that records timestamped state
	  transitions and notable events.  Useful for post-flight analysis
	  and shell diagnostics.

config AURORA_STATE_MACHINE_AUDIT_LOG_SIZE
	int "Maximum number of audit log entries"
	default 32
	depends on AURORA_STATE_MACHINE_AUDIT
	help
	  Size of the ring buffer used for the audit log.  Oldest entries
	  are silently overwritten when full.

config AURORA_STATE_MACHINE_SHELL
	bool "State machine shell commands"
	depends on SHELL
	help
	  Enable shell commands for inspecting state machine type,
	  current state, forcing transitions, and viewing the audit log.

endif
